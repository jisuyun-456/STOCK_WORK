{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Paperclip Research Results",
  "description": "Paperclip 6에이전트 Routine 산출물 — GitHub Actions Phase 2.5에서 Gemini/Claude 대체",
  "type": "object",
  "required": ["generated_at", "regime", "verdicts"],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Paperclip Routine 실행 완료 시각 (ISO 8601)"
    },
    "routine_id": {
      "type": "string",
      "description": "Paperclip Routine 실행 ID (추적용)"
    },
    "regime": {
      "type": "object",
      "description": "Market-Scanner + Chief Trader 레짐 판단",
      "required": ["regime", "macro_sentiment"],
      "properties": {
        "regime": {
          "type": "string",
          "enum": ["BULL", "NEUTRAL", "BEAR", "CRISIS"]
        },
        "macro_sentiment": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "매크로 감성 스코어 (-1.0 극도 부정 ~ +1.0 극도 긍정)"
        },
        "key_events": {
          "type": "array",
          "items": {"type": "string"},
          "description": "오늘의 주요 매크로 이벤트"
        },
        "reasoning": {
          "type": "string",
          "description": "레짐 판단 근거"
        }
      }
    },
    "verdicts": {
      "type": "object",
      "description": "종목별 리서치 verdict 배열 (key = symbol)",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["agent", "direction", "confidence_delta", "conviction", "reasoning"],
          "properties": {
            "agent": {
              "type": "string",
              "enum": ["market_scanner", "fundamental_analyst", "quant_strategist", "risk_sentinel", "portfolio_monitor"]
            },
            "direction": {
              "type": "string",
              "enum": ["AGREE", "DISAGREE", "VETO"]
            },
            "confidence_delta": {
              "type": "number",
              "minimum": -0.3,
              "maximum": 0.3
            },
            "conviction": {
              "type": "string",
              "enum": ["STRONG", "MODERATE", "WEAK"]
            },
            "reasoning": {
              "type": "string"
            },
            "key_metrics": {
              "type": "object"
            }
          }
        }
      }
    },
    "portfolio_assessment": {
      "type": "object",
      "description": "Portfolio-Monitor 전체 포트폴리오 평가",
      "properties": {
        "health": {
          "type": "string",
          "enum": ["HEALTHY", "CAUTION", "WARNING", "CRITICAL"]
        },
        "mdd_status": {
          "type": "object"
        },
        "rebalance_recommendations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "anomalies": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "monitor_hints": {
      "type": "object",
      "description": "오늘의 인트라데이 모니터링 주의사항 (Python 모니터가 참조)",
      "properties": {
        "watch_symbols": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "symbol": {"type": "string"},
              "reason": {"type": "string"},
              "suggested_action": {"type": "string"}
            }
          }
        },
        "regime_warning": {"type": "string"}
      }
    }
  }
}
